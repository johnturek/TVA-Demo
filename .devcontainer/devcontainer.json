{
  "name": "TVA Workshop",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/powershell:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "initializeCommand": "git submodule update --init --recursive 2>/dev/null || true",
  "postCreateCommand": "bash -c 'git submodule update --init --recursive && npm install && pip install -r boilerplate/mcp-backend/requirements.txt && pip install \"azure-ai-projects>=2.0.0\" azure-identity azure-search-documents && cp -n .env.example .env 2>/dev/null || true && echo \"✅ Workshop environment ready. Run: az login --use-device-code\"'",
  "customizations": {
    "vscode": {
      "extensions": [
        "humao.rest-client",
        "ms-python.python",
        "ms-vscode.powershell",
        "ms-azuretools.vscode-azurecontainerapps",
        "ms-vscode.azure-account"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "pwsh",
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "MCP Server",
      "onAutoForward": "notify"
    }
  }
}
