{
  "name": "TVA Workshop",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/powershell:1": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },
  "initializeCommand": "git submodule update --init --recursive 2>/dev/null || true",
  "postCreateCommand": "bash -c 'git submodule update --init --recursive && npm install && pip install --quiet -r boilerplate/mcp-backend/requirements.txt -r boilerplate/mcp-backend/foundry-lab/requirements.txt && cp -n .env.example .env 2>/dev/null || true && echo \"\" && echo \"✅ Workshop environment ready!\" && echo \"   Next step: az login --use-device-code\" && echo \"\"'",
  "customizations": {
    "vscode": {
      "extensions": [
        "humao.rest-client",
        "ms-python.python",
        "ms-vscode.powershell",
        "ms-azuretools.vscode-azurecontainerapps",
        "ms-vscode.azure-account"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "MCP Server",
      "onAutoForward": "notify"
    }
  }
}
