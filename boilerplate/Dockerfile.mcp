FROM node:20-alpine
WORKDIR /app
COPY mcp-server-stub.js .
RUN echo '{"name":"tva-mcp-server","version":"1.0.0","dependencies":{"express":"^4.18.2"}}' > package.json && \
    npm install
EXPOSE 3002
HEALTHCHECK --interval=30s --timeout=3s CMD wget -qO- http://localhost:3002/health || exit 1
CMD ["node", "mcp-server-stub.js"]
