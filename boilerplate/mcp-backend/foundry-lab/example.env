# ─── Azure Subscription ───────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=foundry-lab-rg
AZURE_LOCATION=eastus2

# ─── AI Foundry Account & Project ─────────────────────────────────────────────
# Populated by deploy.ps1 after infrastructure deployment
AZURE_AI_FOUNDRY_ACCOUNT_NAME=
AZURE_AI_PROJECT_NAME=
AZURE_AI_PROJECT_ENDPOINT=

# ─── Azure AI Search ──────────────────────────────────────────────────────────
AZURE_SEARCH_SERVICE_NAME=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=foundry-lab-index

# ─── Model Deployments ────────────────────────────────────────────────────────
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ─── Optional: Foundry Workflow Agent (Lab 04 Pattern 5) ──────────────────────
# Name of a workflow agent registered in the AI Foundry portal
FOUNDRY_WORKFLOW_AGENT_NAME=

# ─── Optional: Disable Code Interpreter (Lab 03 Exercise 2) ───────────────────
# Set to true if Code Interpreter containers are not available in your region/project
DISABLE_CODE_INTERPRETER_LAB=

# ─── Optional: Bing Search (for grounding) ────────────────────────────────────
BING_CONNECTION_NAME=

# ─── Lab 07: AI Foundry Agent API ──────────────────────────────────────────────
# Name and version of the hosted agent to call (YAML-based or portal-developed)
AZURE_AGENT_NAME=TvaDamSafetyInspector
AZURE_AGENT_VERSION=1
# OBO auth: reuse OBO_CLIENT_ID, OBO_CLIENT_SECRET, OBO_TENANT_ID from root .env
# OBO_SCOPE defaults to https://cognitiveservices.azure.com/.default

# ─── Lab 07: Container Apps Infrastructure ────────────────────────────────────
# deploy-lab07.sh needs an ACR and Container Apps Environment (created by the
# root deploy.ps1, NOT foundry-lab/deploy.ps1).
#
# Auto-discovery uses MCP_WORKSHOP_PREFIX + MCP_WORKSHOP_LABNUM to derive names
# matching the root deploy.ps1 naming convention. Set these to match the
# -Prefix and -LabNum you passed to the root deploy.ps1:
MCP_WORKSHOP_PREFIX=mcp-workshop
MCP_WORKSHOP_LABNUM=
#
