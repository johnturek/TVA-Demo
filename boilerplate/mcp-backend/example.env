# TVA MCP Server — Example Environment
# Copy this file to .env and fill in your values.
# For local dev (auth disabled), the defaults below are sufficient.

# --- MCP Server ---
MCP_REQUIRE_AUTH=false
MCP_PRM_METADATA_PATH=prm_metadata.json
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8000
FASTMCP_SCHEME=http

# --- OAuth / Entra ID (only needed when MCP_REQUIRE_AUTH=true) ---
OAUTH_AUTHORIZATION_URL=https://login.microsoftonline.com/common/oauth2/v2.0/authorize
OAUTH_TOKEN_URL=https://login.microsoftonline.com/common/oauth2/v2.0/token
OAUTH_DEVICE_CODE_URL=https://login.microsoftonline.com/common/oauth2/v2.0/devicecode
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPES=openid profile

# --- OBO (only needed when MCP_REQUIRE_AUTH=true) ---
OBO_CLIENT_ID=
OBO_CLIENT_SECRET=
OBO_TENANT_ID=
OBO_SCOPE=https://graph.microsoft.com/.default

# --- Azure AI Foundry ---
AZURE_AI_PROJECT_ENDPOINT=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# --- Azure AI Search ---
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=tva-knowledge-base

# --- Session / Timeout ---
MCP_SESSION_TOKEN_TTL_SECONDS=3600
OAUTH_TIMEOUT_SECONDS=900
