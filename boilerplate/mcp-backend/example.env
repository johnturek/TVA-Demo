# --- Required ---
MCP_REQUIRE_AUTH=true
MCP_PRM_METADATA_PATH=prm_metadata.json
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8000
FASTMCP_SCHEME=http
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=
OAUTH_DEVICE_CODE_URL=
OAUTH_CLIENT_ID=
OAUTH_SCOPES=

# --- OBO (single-app model) ---
# Same app as OAUTH_CLIENT_ID — the app is both the JWT audience and the OBO confidential client.
OBO_CLIENT_ID=
OBO_CLIENT_SECRET=
OBO_TENANT_ID=
OBO_SCOPE=https://graph.microsoft.com/.default

# --- Optional ---
MCP_SESSION_TOKEN_TTL_SECONDS=3600
OAUTH_TIMEOUT_SECONDS=900
