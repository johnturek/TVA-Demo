# ============================================================
# TVA Workshop — Environment Variables
# Copy this file to .env and fill in your values
# Values marked AUTO are populated by deploy.ps1 / setup-entra-apps.ps1
# ============================================================

# --- Microsoft Foundry / Azure AI Projects (Lab 1) ---
# Get these from the Foundry portal after creating your project
AZURE_AI_PROJECT_ENDPOINT=https://tva-workshop.services.ai.azure.com/api/projects/tva-doc-processor-[yourname]
AZURE_AGENT_NAME=TVA Document Processor  # Agent name from Lab 1 agent playground
AZURE_OPENAI_ENDPOINT=https://tva-workshop.openai.azure.com/
AZURE_OPENAI_KEY=                        # From Models + endpoints in Foundry
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Foundry Agent Endpoint (Lab 2) ---
# Same as AZURE_AI_PROJECT_ENDPOINT — used by Copilot Studio HTTP Request nodes
FOUNDRY_AGENT_ENDPOINT=https://tva-workshop.services.ai.azure.com/api/projects/tva-doc-processor-[yourname]
FOUNDRY_AGENT_KEY=                       # Same as AZURE_OPENAI_KEY above

# --- MCP Server (boilerplate/mcp-backend) ---
MCP_REQUIRE_AUTH=false                   # Set to true for production
MCP_PRM_METADATA_PATH=prm_metadata.json
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8000
FASTMCP_SCHEME=http

# --- OAuth / Entra ID (AUTO — set by setup-entra-apps.ps1) ---
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=
OAUTH_DEVICE_CODE_URL=
OAUTH_CLIENT_ID=
OAUTH_SCOPES=
OAUTH_CLIENT_SECRET=

# --- OBO — On-Behalf-Of (AUTO — same app as above, single-app model) ---
OBO_CLIENT_ID=
OBO_CLIENT_SECRET=
OBO_TENANT_ID=
OBO_SCOPE=https://graph.microsoft.com/.default

# --- Session / Timeout ---
MCP_SESSION_TOKEN_TTL_SECONDS=3600
OAUTH_TIMEOUT_SECONDS=900

# --- Production APIM outputs (AUTO — set by deploy.ps1) ---
APIM_NAME=
APIM_GATEWAY=
MCP_ENDPOINT=
PRM_METADATA=
BACKEND_URL=
JWT_AUDIENCE=
JWT_ISSUER=
